# Solana RPC endpoint. The public mainnet RPC is heavily rate-limited and
# rejects sendTransaction; sign up for a free Helius / Triton / QuickNode
# key and drop it in here.
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Prediction API base URL. Defaults to the same-origin proxy in
# next.config.ts, which rewrites to https://api.jup.ag/prediction/v1
# to bypass browser CORS/rate-limit issues.
NEXT_PUBLIC_API_URL=https://api.jup.ag/prediction/v1

# Anthropic API key — server-only (never prefixed with NEXT_PUBLIC_).
# Powers the "Ask AI" popup on market cards. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=